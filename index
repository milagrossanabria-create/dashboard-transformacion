                                            </template>
                                            <template x-if="editMode">
                                                <input type="number" min="0" max="100" x-model.number="item.progress" @input="syncFinancialsFromInitiatives()" class="w-14 bg-slate-900 text-center font-black px-2 py-1 rounded-lg border border-slate-800">
                                            </template>
                                            
                                            <div class="w-16 bg-slate-950 h-2 rounded-full overflow-hidden p-0.5 border border-slate-900 hidden sm:block">
                                                <div class="h-full rounded-full" :class="item.isBlocked ? 'bg-rose-500' : 'bg-amber-400'" :style="'width: ' + item.progress + '%'"></div>
                                            </div>
                                        </div>
                                    </td>

                                    <td x-show="editMode" class="px-5 py-4 text-center">
                                        <div class="flex gap-1.5 justify-center">
                                            <button 
                                                @click="item.isBlocked = !item.isBlocked; syncFinancialsFromInitiatives()" 
                                                class="p-2 rounded-xl border transition-all duration-300"
                                                :class="item.isBlocked ? 'bg-emerald-500/10 hover:bg-emerald-500 text-emerald-500 hover:text-white border-emerald-500/20' : 'bg-rose-500/10 hover:bg-rose-500 text-rose-500 hover:text-white border-rose-500/15'"
                                                :title="item.isBlocked ? 'Reactivar Proyecto' : 'Suspender (Stand-by)'">
                                                <i class="fa-solid" :class="item.isBlocked ? 'fa-lock-open' : 'fa-lock'"></i>
                                            </button>
                                            <button 
                                                @click="removeInitiative(item.id)" 
                                                class="bg-rose-500/10 hover:bg-rose-500 text-rose-500 hover:text-white transition-all duration-300 p-2 rounded-xl border border-rose-500/15 shadow-md"
                                                title="Eliminar Iniciativa">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </div>
                                    </td>

                                </tr>
                            </template>
                            <template x-if="getFilteredInitiatives().length === 0">
                                <tr>
                                    <td colspan="7" class="text-center py-8 text-slate-500 uppercase tracking-widest text-[10px] font-bold">
                                        No hay iniciativas cargadas en la vista para el trimestre <span class="text-[#00E676]" x-text="selectedQFilter"></span>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
            </section>
        </div>

        <div x-show="activeTab === 'base_datos'" x-transition:enter="transition ease-out duration-300" class="space-y-8" style="display: none;">
            
            <section class="bg-[#0a1612]/90 border border-emerald-900/40 rounded-3xl p-6 md:p-8 shadow-2xl relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-emerald-500 to-[#00E676]"></div>
                
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6 pb-4 border-b border-emerald-950">
                    <div>
                        <span class="bg-emerald-500/10 text-[#00E676] px-3 py-1 rounded-full text-[10px] uppercase font-bold tracking-wider border border-emerald-500/20">CONEXIÓN NATIVA</span>
                        <h3 class="text-xl font-extrabold text-slate-100 mt-2 flex items-center gap-2">
                            <i class="fa-solid fa-cloud-arrow-down text-[#00E676]"></i>
                            <span>Sincronizador Automático mediante API de Google Script</span>
                        </h3>
                        <p class="text-xs text-slate-400 mt-1">
                            Se conecta con la Aplicación Web publicada para esquivar restricciones de red y bloqueos de CORS.
                        </p>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-end">
                    <div class="lg:col-span-8 space-y-2">
                        <label class="block text-xs font-bold text-slate-300 uppercase tracking-wider">Estado del Sincronizador Dedicado:</label>
                        <input 
                            type="text" 
                            readonly
                            value="Conexión Directa Anti-CORS Configurada con itti.digital" 
                            class="w-full bg-slate-950/50 text-[#00E676] text-xs rounded-xl p-3.5 border border-emerald-900/40 font-bold transition-colors">
                    </div>
                    
                    <div class="lg:col-span-4 flex gap-2">
                        <button 
                            @click="syncFromGoogleSheets()" 
                            :disabled="isSyncing"
                            class="flex-1 bg-[#00E676] disabled:bg-[#00E676]/50 text-slate-950 text-xs font-black p-3.5 rounded-xl hover:bg-[#00c564] transition-all flex items-center justify-center gap-2 shadow-lg">
                            <template x-if="isSyncing">
                                <i class="fa-solid fa-spinner animate-spin"></i>
                            </template>
                            <template x-if="!isSyncing">
                                <i class="fa-solid fa-rotate"></i>
                            </template>
                            <span x-text="isSyncing ? 'Sincronizando...' : 'Sincronizar ahora'"></span>
                        </button>
                    </div>
                </div>

                <template x-if="lastSyncTime">
                    <div class="mt-4 text-[11px] text-emerald-400 font-semibold flex items-center gap-1.5 bg-emerald-950/20 px-3 py-1.5 rounded-lg border border-emerald-900/30 w-fit">
                        <i class="fa-solid fa-circle-check animate-pulse"></i>
                        <span>Última sincronización a través de API exitosa: <span x-text="lastSyncTime"></span></span>
                    </div>
                </template>
            </section>

            <section class="bg-[#070b14]/90 border border-slate-900 rounded-3xl p-6 md:p-8 shadow-xl relative overflow-hidden">
                <div class="flex flex-col lg:flex-row gap-8">
                    
                    <div class="w-full lg:w-1/2 space-y-6">
                        <div class="space-y-2">
                            <span class="bg-[#00E676]/10 text-[#00E676] px-3 py-1 rounded-full text-[10px] uppercase font-bold tracking-wider border border-emerald-500/20">Cargador Manual Alternativo</span>
                            <h3 class="text-xl font-extrabold text-slate-100">Sube tu CSV de Jira o Excel</h3>
                            <p class="text-xs text-slate-400 leading-relaxed">
                                Si quieres importar manualmente datos fuera de la hoja automatizada, puedes arrastrar aquí archivos ordenados de Excel o exportaciones nativas de Jira.
                            </p>
                        </div>

                        <template x-if="importSuccess">
                            <div class="bg-emerald-500/10 border border-emerald-500/20 text-[#00E676] text-xs p-4 rounded-xl flex items-start gap-2.5">
                                <i class="fa-solid fa-circle-check text-base mt-0.5"></i>
                                <span class="font-medium" x-text="importSuccess"></span>
                            </div>
                        </template>
                        <template x-if="importError">
                            <div class="bg-rose-500/10 border border-rose-500/20 text-rose-400 text-xs p-4 rounded-xl flex items-start gap-2.5">
                                <i class="fa-solid fa-circle-exclamation text-base mt-0.5"></i>
                                <span class="font-medium" x-text="importError"></span>
                            </div>
                        </template>
                    </div>

                    <div class="w-full lg:w-1/2 space-y-6">
                        <div class="space-y-2">
                            <h4 class="text-xs font-bold text-slate-300 uppercase tracking-wider flex items-center gap-1.5">
                                <i class="fa-solid fa-paste text-[#00E676]"></i>
                                <span>Carga Rápida (Pegar celdas directamente de Excel/Jira)</span>
                            </h4>
                            <p class="text-[11px] text-slate-500 leading-normal">
                                Copia el bloque de filas de tu hoja de cálculo o exportación y pégalo abajo directamente para procesarlo sin usar archivos.
                            </p>
                        </div>

                        <div class="space-y-3">
                            <textarea 
                                x-model="csvPasteArea"
                                placeholder='Tipo de Incidencia;Clave;Resumen;Estado;Fase;Q de Compromiso;Valor total por iniciativa;Porcentaje de avance del proyecto;Tipo de bloqueo&#10;Tarea;TOMDC-11;Documentación de procesos;FINALIZADO;Finalizado;Q1;1250000;100;None&#10;Tarea;TOMDC-13;Mejoras gestión tickets;EN DESARROLLO;En desarrollo;Q2;450000;45;None'
                                class="w-full h-32 bg-slate-950/80 text-xs text-slate-200 p-4 rounded-2xl border border-slate-900 focus:outline-none focus:border-[#00E676] font-mono leading-relaxed"
                            ></textarea>
                            <div class="flex justify-end">
                                <button 
                                    @click="importCSVData()"
                                    class="bg-[#00E676] text-slate-950 text-xs font-black px-6 py-2.5 rounded-xl hover:bg-[#00c564] transition-all flex items-center gap-2 shadow-lg">
                                    <i class="fa-solid fa-bolt"></i>
                                    <span>Procesar Datos Manuales</span>
                                </button>
                            </div>
                        </div>
                    </div>

                </div>
            </section>
        </div>

        <div class="bg-[#070b14]/50 border border-slate-900 rounded-2xl p-5 mt-10 flex flex-col md:flex-row gap-4 items-center justify-between text-xs text-slate-400 shadow-lg">
            <div class="flex items-center gap-3">
                <div class="bg-emerald-500/10 p-2.5 rounded-xl text-[#00E676] shadow-[0_0_8px_rgba(0,230,118,0.2)]">
                    <i class="fa-solid fa-circle-info text-base"></i>
                </div>
                <div>
                    <strong class="text-slate-200">Sincronización Total Activa:</strong> % Logro = (Resultado / Meta) * 100. Los totales de ambas hojas se recalculan dinámicamente cada vez que ejecutas la sincronización de Google Apps Script.
                </div>
            </div>
            <div class="text-right text-slate-500 font-semibold">
                Soporte oficial integrado para <span class="underline">Base Jira Transformación</span>
            </div>
        </div>

    </div>

    <footer class="bg-slate-950/60 py-5 text-center border-t border-slate-900/60 text-xs text-slate-500 mt-12">
        <p>© 2026 Resumen Ejecutivo - Equipo de Transformación. Desarrollado con excelencia visual e interactiva.</p>
    </footer>

</body>
</html>
