<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transformación - Resumen Ejecutivo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght=300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #050811;
        }
        /* Personalización de inputs para una experiencia limpia */
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        input[type=number] {
            -moz-appearance: textfield;
        }
        /* Efecto de brillo de neón (Glow) */
        .neon-glow-green {
            box-shadow: 0 0 15px rgba(0, 230, 118, 0.15);
        }
        .neon-border-green {
            border-color: rgba(0, 230, 118, 0.4);
        }
        .neon-border-green:hover {
            border-color: rgba(0, 230, 118, 1);
            box-shadow: 0 0 20px rgba(0, 230, 118, 0.25);
        }
    </style>

    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('dashboardApp', () => ({
                // Navegación
                activeTab: 'resumen', // 'resumen', 'iniciativas' o 'base_datos'
                selectedQFilter: 'Todos', // Filtrado por trimestre de iniciativas
                
                // Estado del Dashboard
                editMode: false,
                generalTitle: "Transformación - ",
                generalSubtitle: "Resumen ejecutivo",
                
                // Configuración de sincronización automática de Google Sheets
                sheetUrl: '', // URL del usuario
                isSyncing: false,
                lastSyncTime: '',
                manualDownloadUrl: null, // Url de respaldo para descarga manual si CORS bloquea todo

                // Estados de la base importada
                csvPasteArea: '',
                importSuccess: null,
                importError: null,

                // Etiquetas de las filas anuales
                rowRevenue: {
                    title: "Revenue USD"
                },
                rowProjects: {
                    title: "Proyecto Comprometido"
                },

                // Dataset inicial por Q para Revenue USD (en miles)
                quartersUSD: [
                    { name: "Q1", meta: 5200, resultado: 4850 },
                    { name: "Q2", meta: 6400, resultado: 5900 },
                    { name: "Q3", meta: 5800, resultado: 2300 },
                    { name: "Q4", meta: 7000, resultado: 0 }
                ],

                // Dataset inicial por Q para Proyectos Comprometidos (Unidades)
                quartersProjects: [
                    { name: "Q1", meta: 12, resultado: 12 },
                    { name: "Q2", meta: 15, resultado: 14 },
                    { name: "Q3", meta: 10, resultado: 5 },
                    { name: "Q4", meta: 18, resultado: 0 }
                ],

                // Definición de Estados, porcentajes y paleta cromática exacta
                states: [
                    { id: 'Backlog', name: 'Backlog', range: '1–3%', barColor: 'bg-slate-500', textLight: 'text-slate-400', borderStyle: 'border-slate-500/30' },
                    { id: 'En evaluación', name: 'En evaluación', range: '4–25%', barColor: 'bg-blue-500', textLight: 'text-blue-400', borderStyle: 'border-blue-500/30' },
                    { id: 'En curso', name: 'En curso', range: '26–60%', barColor: 'bg-amber-500', textLight: 'text-amber-400', borderStyle: 'border-amber-500/30' },
                    { id: 'Seg. / Impl.', name: 'Seg. / Impl.', range: '61–99%', barColor: 'bg-emerald-500', textLight: 'text-emerald-400', borderStyle: 'border-emerald-500/30' },
                    { id: 'Finalizado', name: 'Finalizado', range: '100%', barColor: 'bg-teal-400', textLight: 'text-teal-400', borderStyle: 'border-teal-400/30' }
                ],

                // Fases oficiales y mapeo de su respectivo estado de procedencia
                phases: [
                    { name: 'Verificación de planificación de la dirección', state: 'Backlog', defaultProgress: 2 },
                    { name: 'Análisis de viabilidad', state: 'En evaluación', defaultProgress: 10 },
                    { name: 'Análisis AS-IS', state: 'En evaluación', defaultProgress: 18 },
                    { name: 'Pre TO-BE', state: 'En evaluación', defaultProgress: 23 },
                    { name: 'Kick off', state: 'En curso', defaultProgress: 30 },
                    { name: 'Diseño TO-BE', state: 'En curso', defaultProgress: 42 },
                    { name: 'Mesa validación', state: 'En curso', defaultProgress: 50 },
                    { name: 'Socialización', state: 'En curso', defaultProgress: 58 },
                    { name: 'En desarrollo', state: 'Seg. / Impl.', defaultProgress: 70 },
                    { name: 'Pruebas y acompañamiento al stakeholder', state: 'Seg. / Impl.', defaultProgress: 80 },
                    { name: 'Implementación', state: 'Seg. / Impl.', defaultProgress: 90 },
                    { name: 'Medición impacto y lecciones aprendidas', state: 'Seg. / Impl.', defaultProgress: 96 },
                    { name: 'Cierre y Entrega', state: 'Finalizado', defaultProgress: 100 }
                ],
                
                // Dataset inicial alineado a los estados y fases oficiales (Se sobrescribirá con el CSV de Jira/Sheets)
                initiatives: [
                    { id: 1, name: "Migración de Core a la Nube", phase: "Diseño TO-BE", state: "En curso", q: "Q1", usdValue: 1250, progress: 45, isBlocked: false },
                    { id: 2, name: "RPA - Conciliación Financiera", phase: "Cierre y Entrega", state: "Finalizado", q: "Q1", usdValue: 420, progress: 100, isBlocked: false },
                    { id: 3, name: "Portal de Clientes Autogestión", phase: "En desarrollo", state: "Seg. / Impl.", q: "Q2", usdValue: 1800, progress: 70, isBlocked: false },
                    { id: 4, name: "Piloto CRM Omnicanal", phase: "Verificación de planificación de la dirección", state: "Backlog", q: "Q2", usdValue: 600, progress: 2, isBlocked: false },
                    { id: 5, name: "Capacitación Metodologías Ágiles", phase: "Socialización", state: "En curso", q: "Q3", usdValue: 150, progress: 55, isBlocked: false },
                    { id: 6, name: "Arquitectura Big Data Analytics", phase: "En desarrollo", state: "Seg. / Impl.", q: "Q3", usdValue: 2100, progress: 75, isBlocked: true },
                    { id: 7, name: "Gobernanza de Datos y AI Core", phase: "Análisis de viabilidad", state: "En evaluación", q: "Q4", usdValue: 950, progress: 12, isBlocked: false },
                    { id: 8, name: "Motor de Decisiones Real-Time", phase: "Mesa validación", state: "En curso", q: "Q4", usdValue: 1450, progress: 50, isBlocked: false },
                    { id: 9, name: "Migración Canal Digital Empresa", phase: "Implementación", state: "Seg. / Impl.", q: "Q1", usdValue: 890, progress: 90, isBlocked: false },
                    { id: 10, name: "Seguridad Zero Trust Fase 1", phase: "Pre TO-BE", state: "En evaluación", q: "Q2", usdValue: 1100, progress: 20, isBlocked: true }
                ],

                // Variables para nueva iniciativa
                newInitiative: {
                    name: '',
                    phase: 'Verificación de planificación de la dirección',
                    state: 'Backlog',
                    q: 'Q1',
                    usdValue: 100,
                    progress: 2,
                    isBlocked: false
                },

                // Inicializador automático de Alpine
                init() {
                    this.syncFinancialsFromInitiatives();
                    
                    // Recuperar URL de Google Sheets si ya existía una guardada en este navegador
                    const savedUrl = localStorage.getItem('transformation_sheet_url');
                    if (savedUrl) {
                        this.sheetUrl = savedUrl;
                        this.syncFromGoogleSheets();
                    }
                },

                // Sincronizador Directo con Google Apps Script (Anti-CORS)
                async syncFromGoogleSheets() {
                    this.isSyncing = true;
                    this.importError = null;
                    this.importSuccess = null;
                    this.manualDownloadUrl = null;

                    // Tu URL exacta de Google Apps Script publicada como Aplicación Web
                    const webAppUrl = 'https://script.google.com/a/macros/itti.digital/s/AKfycbzWJ8I8LBXkEpUR5boMYpDClZq9opgHfPATBk0PwfHIjwcoLD3iC_k_AzXNlTkVyri8kw/exec';

                    try {
                        const response = await fetch(webAppUrl);
                        if (!response.ok) throw new Error("Error en la respuesta de la Web App de Google");
                        
                        const data = await response.json();
                        
                        if (data && data.length > 0) {
                            // Mapeamos dinámicamente las propiedades del JSON normalizando las claves a minúsculas
                            this.initiatives = data.map((item, i) => {
                                // Convertimos el objeto para poder hacer búsquedas insensibles a mayúsculas/minúsculas en los encabezados
                                const cleanItem = {};
                                Object.keys(item).forEach(k => {
                                    cleanItem[k.toLowerCase().trim()] = item[k];
                                });

                                // Intentos de mapear presupuesto / valor
                                let rawUsd = String(cleanItem['valor total por iniciativa'] || cleanItem['valor de bc neto'] || cleanItem['usd_k'] || cleanItem['valor_usd'] || cleanItem['presupuesto'] || cleanItem['usd'] || '0');
                                rawUsd = rawUsd.replace(/[^0-9.,-]/g, '').replace(',', '.');
                                let usdValue = parseFloat(rawUsd) || 0;
                                if (usdValue > 50000) usdValue = Math.round(usdValue / 1000);

                                // Intentos de mapear progreso / avance %
                                let rawProgress = String(cleanItem['porcentaje de avance'] || cleanItem['avance'] || cleanItem['progreso'] || cleanItem['progress'] || '');
                                rawProgress = rawProgress.replace(/[^0-9.,-]/g, '').replace(',', '.');
                                let progress = parseFloat(rawProgress);

                                // Intentos de mapear bloqueo
                                let rawBlock = String(cleanItem['tipo de bloqueo'] || cleanItem['bloqueado'] || cleanItem['blocked'] || '').toLowerCase().trim();
                                let isBlocked = rawBlock.length > 0 && rawBlock !== 'no' && rawBlock !== 'none' && rawBlock !== 'false';

                                // Intentos de mapear nombre
                                let keyVal = cleanItem['clave'] || cleanItem['key'] || '';
                                let summaryVal = cleanItem['resumen'] || cleanItem['summary'] || cleanItem['iniciativa'] || cleanItem['nombre'] || '';
                                let name = summaryVal ? (keyVal ? `[${keyVal}] ${summaryVal}` : summaryVal) : `Línea ${i + 1}`;

                                // Intentos de mapear fase y estado
                                let rawPhase = String(cleanItem['fase'] || cleanItem['phase'] || cleanItem['estado'] || cleanItem['status'] || '').trim();
                                let phase = 'Verificación de planificación de la dirección';

                                if (rawPhase) {
                                    const norm = rawPhase.toLowerCase();
                                    if (norm.includes('cierre') || norm.includes('entrega') || norm === 'finalizado' || norm === 'done' || norm === 'resolved') {
                                        phase = 'Cierre y Entrega';
                                    } else if (norm.includes('implementación') || norm.includes('implementacion')) {
                                        phase = 'Implementación';
                                    } else if (norm.includes('desarrollo') || norm === 'en desarrollo' || norm === 'in progress') {
                                        phase = 'En desarrollo';
                                    } else if (norm.includes('pruebas') || norm.includes('testing')) {
                                        phase = 'Pruebas y acompañamiento al stakeholder';
                                    } else if (norm.includes('socialización') || norm.includes('socializacion')) {
                                        phase = 'Socialización';
                                    } else if (norm.includes('validación') || norm.includes('validacion')) {
                                        phase = 'Mesa validación';
                                    } else if (norm.includes('diseño to-be') || norm.includes('to-be') || norm.includes('tobe')) {
                                        phase = 'Diseño TO-BE';
                                    } else if (norm.includes('kick off') || norm.includes('kickoff')) {
                                        phase = 'Kick off';
                                    } else if (norm.includes('pre to-be') || norm.includes('pre-to-be')) {
                                        phase = 'Pre TO-BE';
                                    } else if (norm.includes('as-is') || norm.includes('asis')) {
                                        phase = 'Análisis AS-IS';
                                    } else if (norm.includes('viabilidad') || norm.includes('feasibility')) {
                                        phase = 'Análisis de viabilidad';
                                    } else if (norm.includes('planificación') || norm.includes('planificacion') || norm.includes('backlog') || norm === 'to do') {
                                        phase = 'Verificación de planificación de la dirección';
                                    } else {
                                        const matched = this.phases.find(p => p.name.toLowerCase().includes(norm) || norm.includes(p.name.toLowerCase()));
                                        if (matched) phase = matched.name;
                                    }
                                }

                                let matchPhase = this.phases.find(p => p.name.toLowerCase() === phase.toLowerCase()) || this.phases[0];
                                if (isNaN(progress)) progress = matchPhase.defaultProgress;

                                let qVal = String(cleanItem['q de compromiso'] || cleanItem['q'] || cleanItem['trimestre'] || cleanItem['compromiso'] || 'Q1').toUpperCase().trim();
                                if (!['Q1', 'Q2', 'Q3', 'Q4'].includes(qVal)) {
                                    const qMatch = qVal.match(/Q[1-4]/i);
                                    qVal = qMatch ? qMatch[0].toUpperCase() : 'Q1';
                                }

                                return {
                                    id: Date.now() + i,
                                    name: name,
                                    phase: matchPhase.name,
                                    state: matchPhase.state,
                                    q: qVal,
                                    usdValue: usdValue,
                                    progress: progress,
                                    isBlocked: isBlocked
                                };
                            });

                            this.syncFinancialsFromInitiatives();
                            if (this.sheetUrl.trim()) {
                                localStorage.setItem('transformation_sheet_url', this.sheetUrl.trim());
                            }
                            const now = new Date();
                            this.lastSyncTime = now.toLocaleTimeString();
                            this.importSuccess = `¡Sincronizado con éxito! Datos cargados directamente desde la API de Google Sheets sin errores de CORS a las ${this.lastSyncTime}.`;
                        } else {
                            this.importError = "El script de Google no devolvió datos estructurados válidos.";
                        }
                    } catch (err) {
                        console.error(err);
                        this.importError = "Error al conectar con la Web App: " + err.message + ". Comprueba que el script de Apps Script esté implementado para acceso de 'Cualquier persona'.";
                    } finally {
                        this.isSyncing = false;
                    }
                },

                // Restaurar estado inicial recargando la página
                resetData() {
                    localStorage.removeItem('transformation_sheet_url');
                    location.reload();
                },

                // Borrar conexión de Google Sheets
                disconnectSheets() {
                    this.sheetUrl = '';
                    localStorage.removeItem('transformation_sheet_url');
                    this.lastSyncTime = '';
                    this.manualDownloadUrl = null;
                    this.importSuccess = "Se ha desconectado Google Sheets. Presiona 'Restablecer' si deseas volver a los datos demo.";
                },

                // Al cambiar la fase, asocia automáticamente el estado y progreso por defecto
                onPhaseChange(targetObj) {
                    const match = this.phases.find(p => p.name === targetObj.phase);
                    if (match) {
                        targetObj.state = match.state;
                        targetObj.progress = match.defaultProgress;
                    }
                },

                getFilteredInitiatives() {
                    if (this.selectedQFilter === 'Todos') {
                        return this.initiatives;
                    }
                    return this.initiatives.filter(item => item.q === this.selectedQFilter);
                },

                getFilteredUSDTotal() {
                    return this.getFilteredInitiatives().reduce((sum, item) => sum + item.usdValue, 0);
                },

                getFilteredAvgProgress() {
                    const list = this.getFilteredInitiatives();
                    if (list.length === 0) return 0;
                    const sum = list.reduce((acc, item) => acc + item.progress, 0);
                    return Math.round(sum / list.length);
                },

                getFilteredCriticalCount() {
                    return this.getFilteredInitiatives().filter(item => item.isBlocked).length;
                },

                // Devuelve datos agregados para la matriz (Fase x Estado)
                getMatrixCell(phaseName, stateId) {
                    const matched = this.getFilteredInitiatives().filter(
                        item => item.phase === phaseName && item.state === stateId
                    );
                    const count = matched.length;
                    const usdValue = matched.reduce((sum, item) => sum + item.usdValue, 0);
                    const hasBlocked = matched.some(item => item.isBlocked);
                    return { count, usdValue, hasBlocked };
                },

                // Devuelve totales agregados de columna (Estado)
                getStateTotals(stateId) {
                    const matched = this.getFilteredInitiatives().filter(item => item.state === stateId);
                    const count = matched.length;
                    const usdValue = matched.reduce((sum, item) => sum + item.usdValue, 0);
                    return { count, usdValue };
                },

                // Devuelve el avance promedio de una columna (Estado)
                getStateAvgProgress(stateId) {
                    const matched = this.getFilteredInitiatives().filter(item => item.state === stateId);
                    if (matched.length === 0) return 0;
                    const sum = matched.reduce((acc, item) => acc + item.progress, 0);
                    return Math.round(sum / matched.length);
                },

                // Agregar iniciativa individual
                addInitiative() {
                    if (!this.newInitiative.name.trim()) return;
                    this.initiatives.push({
                        id: Date.now(),
                        name: this.newInitiative.name,
                        phase: this.newInitiative.phase,
                        state: this.newInitiative.state,
                        q: this.newInitiative.q,
                        usdValue: Number(this.newInitiative.usdValue) || 0,
                        progress: Number(this.newInitiative.progress) || 0,
                        isBlocked: this.newInitiative.isBlocked
                    });
                    
                    // Reset temporal
                    this.newInitiative = {
                        name: '',
                        phase: 'Verificación de planificación de la dirección',
                        state: 'Backlog',
                        q: 'Q1',
                        usdValue: 100,
                        progress: 2,
                        isBlocked: false
                    };
                    this.syncFinancialsFromInitiatives();
                },

                removeInitiative(id) {
                    this.initiatives = this.initiatives.filter(item => item.id !== id);
                    this.syncFinancialsFromInitiatives();
                },

                // Formateador de separadores de miles
                formatNumber(val) {
                    if (val === undefined || val === null || isNaN(val)) return '0';
                    return new Intl.NumberFormat('de-DE').format(Math.round(val));
                },

                // Calcula la suma de las tablas de desglose por Q
                calculateSum(type, field) {
                    let dataset = type === 'usd' ? this.quartersUSD : this.quartersProjects;
                    return dataset.reduce((acc, curr) => {
                        let val = parseFloat(curr[field]);
                        return acc + (isNaN(val) ? 0 : val);
                    }, 0);
                },

                calculatePercentage(resultado, meta) {
                    if (!meta || meta === 0) return '0.0';
                    let r = parseFloat(resultado);
                    let m = parseFloat(meta);
                    if (isNaN(r) || isNaN(m)) return '0.0';
                    
                    let percent = (r / m) * 100;
                    return percent.toFixed(1);
                },

                // Analizador robusto de filas de CSV con soporte para comas dentro de textos entrecomillados
                parseCSVLine(line, separator) {
                    const result = [];
                    let current = '';
                    let inQuotes = false;
                    for (let i = 0; i < line.length; i++) {
                        const char = line[i];
                        if (char === '"' || char === "'") {
                            inQuotes = !inQuotes;
                        } else if (char === separator && !inQuotes) {
                            result.push(current.trim());
                            current = '';
                        } else {
                            current += char;
                        }
                    }
                    result.push(current.trim());
                    return result;
                },

                // Sincroniza dinámicamente las tablas de metas anuales con base en los datos de iniciativas
                syncFinancialsFromInitiatives() {
                    const qUSDResult = { 'Q1': 0, 'Q2': 0, 'Q3': 0, 'Q4': 0 };
                    const qProjectsResult = { 'Q1': 0, 'Q2': 0, 'Q3': 0, 'Q4': 0 };

                    this.initiatives.forEach(item => {
                        const qKey = item.q;
                        if (qUSDResult[qKey] !== undefined) {
                            qUSDResult[qKey] += item.usdValue;
                        }
                        if (qProjectsResult[qKey] !== undefined) {
                            if (item.progress >= 100 || item.state === 'Finalizado') {
                                qProjectsResult[qKey]++;
                            }
                        }
                    });

                    this.quartersUSD.forEach(q => {
                        q.resultado = qUSDResult[q.name] || 0;
                    });
                    this.quartersProjects.forEach(q => {
                        q.resultado = qProjectsResult[q.name] || 0;
                    });
                },

                // Procesamiento y parseo de bases de datos pegadas manualmente
                importCSVData(textToParse) {
                    try {
                        const rawText = textToParse || this.csvPasteArea;
                        if (!rawText.trim()) {
                            this.importError = "Los datos están vacíos. Por favor revisa la carga.";
                            return;
                        }

                        const lines = rawText.split('\n').map(l => l.trim()).filter(l => l.length > 0);
                        if (lines.length < 2) {
                            this.importError = "La estructura cargada debe tener al menos la cabecera y una fila de datos.";
                            return;
                        }

                        const headerLine = lines[0];
                        let separator = ';';
                        if (headerLine.includes('\t')) separator = '\t';
                        else if (headerLine.includes(';')) separator = ';';
                        else if (headerLine.includes(',')) separator = ',';

                        const headers = this.parseCSVLine(headerLine, separator).map(h => 
                            h.replace(/["']/g, "").trim().toLowerCase()
                        );

                        const idxClave = headers.findIndex(h => h.includes('clave') || h.includes('key'));
                        const idxResumen = headers.findIndex(h => h.includes('resumen') || h.includes('summary') || h.includes('iniciativa') || h.includes('nombre'));
                        const idxFase = headers.findIndex(h => h.includes('fase') || h.includes('phase'));
                        const idxEstado = headers.findIndex(h => h.includes('estado') || h.includes('status'));
                        const idxQ = headers.findIndex(h => h.includes('q de compromiso') || h === 'q' || h.includes('trimestre') || h.includes('compromiso'));
                        const idxUSD = headers.findIndex(h => h.includes('valor total por iniciativa') || h.includes('valor de bc neto') || h.includes('usd_k') || h.includes('valor_usd') || h.includes('presupuesto') || h.includes('usd'));
                        const idxAvance = headers.findIndex(h => h.includes('porcentaje de avance') || h.includes('avance') || h.includes('progreso') || h.includes('progress'));
                        const idxBloqueo = headers.findIndex(h => h.includes('tipo de bloqueo') || h.includes('bloqueado') || h.includes('blocked'));

                        const parsedList = [];
                        
                        for (let i = 1; i < lines.length; i++) {
                            const rawCols = this.parseCSVLine(lines[i], separator);
                            if (rawCols.length === 0 || (rawCols.length === 1 && rawCols[0] === "")) continue;

                            let keyVal = idxClave !== -1 ? rawCols[idxClave] : '';
                            let summaryVal = idxResumen !== -1 ? rawCols[idxResumen] : '';
                            let name = summaryVal ? (keyVal ? `[${keyVal}] ${summaryVal}` : summaryVal) : `Línea ${i}`;

                            let rawPhase = (idxFase !== -1 ? rawCols[idxFase] : (idxEstado !== -1 ? rawCols[idxEstado] : '')).trim();
                            let phase = 'Verificación de planificación de la dirección';

                            if (rawPhase) {
                                const norm = rawPhase.toLowerCase();
                                if (norm.includes('cierre') || norm.includes('entrega') || norm === 'finalizado' || norm === 'done' || norm === 'resolved') {
                                    phase = 'Cierre y Entrega';
                                } else if (norm.includes('implementación') || norm.includes('implementacion')) {
                                    phase = 'Implementación';
                                } else if (norm.includes('desarrollo') || norm === 'en desarrollo' || norm === 'in progress') {
                                    phase = 'En desarrollo';
                                } else if (norm.includes('pruebas') || norm.includes('testing')) {
                                    phase = 'Pruebas y acompañamiento al stakeholder';
                                } else if (norm.includes('socialización') || norm.includes('socializacion')) {
                                    phase = 'Socialización';
                                } else if (norm.includes('validación') || norm.includes('validacion')) {
                                    phase = 'Mesa validación';
                                } else if (norm.includes('diseño to-be') || norm.includes('to-be') || norm.includes('tobe')) {
                                    phase = 'Diseño TO-BE';
                                } else if (norm.includes('kick off') || norm.includes('kickoff')) {
                                    phase = 'Kick off';
                                } else if (norm.includes('pre to-be') || norm.includes('pre-to-be')) {
                                    phase = 'Pre TO-BE';
                                } else if (norm.includes('as-is') || norm.includes('asis')) {
                                    phase = 'Análisis AS-IS';
                                } else if (norm.includes('viabilidad') || norm.includes('feasibility')) {
                                    phase = 'Análisis de viabilidad';
                                } else if (norm.includes('planificación') || norm.includes('planificacion') || norm.includes('backlog') || norm === 'to do') {
                                    phase = 'Verificación de planificación de la dirección';
                                }
                            }

                            let matchPhase = this.phases.find(p => p.name.toLowerCase() === phase.toLowerCase()) || this.phases[0];

                            let qVal = idxQ !== -1 ? rawCols[idxQ].toUpperCase().trim() : 'Q1';
                            if (!['Q1', 'Q2', 'Q3', 'Q4'].includes(qVal)) {
                                const qMatch = qVal.match(/Q[1-4]/i);
                                qVal = qMatch ? qMatch[0].toUpperCase() : 'Q1';
                            }

                            let rawUsd = idxUSD !== -1 ? rawCols[idxUSD] : '0';
                            rawUsd = rawUsd.replace(/[^0-9.,-]/g, '').replace(',', '.');
                            let usdValue = parseFloat(rawUsd) || 0;
                            if (usdValue > 50000) usdValue = Math.round(usdValue / 1000);

                            let rawProgress = idxAvance !== -1 ? rawCols[idxAvance] : '';
                            rawProgress = rawProgress.replace(/[^0-9.,-]/g, '').replace(',', '.');
                            let progress = parseFloat(rawProgress);
                            if (isNaN(progress)) progress = matchPhase.defaultProgress;

                            let rawBlock = idxBloqueo !== -1 ? rawCols[idxBloqueo].toLowerCase().trim() : '';
                            const isBlocked = rawBlock.length > 0 && rawBlock !== 'no' && rawBlock !== 'none' && rawBlock !== 'false';

                            parsedList.push({
                                id: Date.now() + i,
                                name: name,
                                phase: matchPhase.name,
                                state: matchPhase.state,
                                q: qVal,
                                usdValue: usdValue,
                                progress: progress,
                                isBlocked: isBlocked
                            });
                        }

                        this.initiatives = parsedList;
                        this.syncFinancialsFromInitiatives();
                        
                        this.importError = null;
                        this.importSuccess = `¡Excelente! Datos manuales procesados con éxito. Se importaron ${parsedList.length} iniciativas.`;
                        this.csvPasteArea = '';
                    } catch (err) {
                        this.importError = "No se pudo interpretar el formato de los datos: " + err.message;
                        this.importSuccess = null;
                    }
                }
            }));
        });
